<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="20260714000001-1" author="brahim">
        <createTable tableName="task_history">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_task_history"/>
            </column>
            <column name="task_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="bigint"/>
            <column name="action" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="old_value" type="varchar(500)"/>
            <column name="new_value" type="varchar(500)"/>
            <column name="created_at" type="datetime(6)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="20260714000001-2" author="brahim">
        <addForeignKeyConstraint baseColumnNames="task_id"
                                 baseTableName="task_history"
                                 constraintName="fk_task_history__task_id"
                                 referencedColumnNames="id"
                                 referencedTableName="task"/>
    </changeSet>
    <changeSet id="20260714000001-3" author="brahim">
        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="task_history"
                                 constraintName="fk_task_history__user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="jhi_user"/>
    </changeSet>
</databaseChangeLog>
