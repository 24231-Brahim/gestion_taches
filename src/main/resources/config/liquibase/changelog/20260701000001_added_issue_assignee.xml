<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="20260701000001-1" author="jhipster">
        <addColumn tableName="issue">
            <column name="assignee_id" type="bigint" remarks="Reference to the user assigned to this issue">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="20260701000001-2" author="jhipster">
        <addForeignKeyConstraint
            baseTableName="issue"
            baseColumnNames="assignee_id"
            constraintName="fk_issue__assignee_id"
            referencedTableName="jhi_user"
            referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>
